generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  BARBER
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  CANCELED
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BANK_TRANSFER
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

model User {
  id            String             @id @default(cuid())
  name          String
  email         String             @unique
  phone         String?
  passwordHash  String
  avatarUrl     String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  memberships   ShopMembership[]
  barberProfile Barber?
  auditLogs     AuditLog[]
}

model BarberShop {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  document        String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  timezone        String           @default("America/Sao_Paulo")
  openingTime     String           @default("09:00")
  closingTime     String           @default("20:00")
  logoUrl         String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  memberships     ShopMembership[]
  customers       Customer[]
  barbers         Barber[]
  services        Service[]
  appointments    Appointment[]
  payments        Payment[]
  products        Product[]
  stockMovements  StockMovement[]
  expenses        Expense[]
  commissions     Commission[]
  notifications   Notification[]
}

model ShopMembership {
  id        String     @id @default(cuid())
  userId    String
  shopId    String
  role      UserRole   @default(BARBER)
  createdAt DateTime   @default(now())
  shop      BarberShop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId, role])
}

model Customer {
  id              String        @id @default(cuid())
  shopId          String
  name            String
  phone           String
  email           String?
  birthday        DateTime?
  notes           String?
  totalSpentCents Int           @default(0)
  lastVisitAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  shop            BarberShop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointments    Appointment[]
  payments        Payment[]

  @@unique([shopId, phone])
  @@index([shopId, name])
}

model Barber {
  id              String        @id @default(cuid())
  shopId          String
  userId          String?       @unique
  name            String
  specialty       String?
  commissionRate  Decimal       @default(0.4) @db.Decimal(5, 2)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  shop            BarberShop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments    Appointment[]
  appointmentServices AppointmentService[]
  commissions     Commission[]

  @@index([shopId, isActive])
}

model Service {
  id            String        @id @default(cuid())
  shopId        String
  name          String
  description   String?
  durationMin   Int
  priceCents    Int
  color         String        @default("#D4A017")
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  shop          BarberShop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  appointmentServices AppointmentService[]

  @@unique([shopId, name])
  @@index([shopId, isActive])
}

model Appointment {
  id              String            @id @default(cuid())
  shopId          String
  customerId      String
  barberId        String
  serviceId       String
  startsAt        DateTime
  endsAt          DateTime
  status          AppointmentStatus @default(SCHEDULED)
  notes           String?
  priceCents      Int
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  shop            BarberShop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  barber          Barber            @relation(fields: [barberId], references: [id], onDelete: Restrict)
  service         Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  payment         Payment?
  commission      Commission?
  services        AppointmentService[]
  logs            AppointmentLog[]
  attachments     AppointmentAttachment[]
  messages        AppointmentMessage[]

  @@index([shopId, startsAt])
  @@index([barberId, startsAt])
  @@index([customerId, startsAt])
}

model AppointmentService {
  id             String      @id @default(cuid())
  appointmentId  String
  serviceId      String
  professionalId String
  price          Int
  duration       Int
  createdAt      DateTime    @default(now())
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service        Service     @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  professional   Barber      @relation(fields: [professionalId], references: [id], onDelete: Restrict)

  @@index([appointmentId])
  @@index([serviceId])
  @@index([professionalId])
}

model AppointmentLog {
  id            String      @id @default(cuid())
  appointmentId String
  userId        String?
  action        String
  description   String
  metadata      Json?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, createdAt])
  @@index([userId, createdAt])
}

model AppointmentAttachment {
  id            String      @id @default(cuid())
  appointmentId String
  fileName      String
  fileUrl       String
  fileType      String
  fileSize      Int
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, createdAt])
}

model AppointmentMessage {
  id            String      @id @default(cuid())
  appointmentId String
  channel       String
  recipient     String
  status        String
  body          String
  sentAt        DateTime?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, createdAt])
  @@index([channel, status])
}

model Payment {
  id            String        @id @default(cuid())
  shopId        String
  appointmentId String?       @unique
  customerId    String?
  amountCents   Int
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  shop          BarberShop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  appointment   Appointment?  @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  customer      Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([shopId, paidAt])
  @@index([shopId, status])
}

model Product {
  id             String          @id @default(cuid())
  shopId         String
  name           String
  sku            String?
  category       String
  salePriceCents Int
  costCents      Int             @default(0)
  stock          Int             @default(0)
  minStock       Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  shop           BarberShop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  movements      StockMovement[]

  @@unique([shopId, name])
  @@index([shopId, category])
}

model StockMovement {
  id          String            @id @default(cuid())
  shopId      String
  productId   String
  type        StockMovementType
  quantity    Int
  reason      String?
  createdAt   DateTime          @default(now())
  shop        BarberShop        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([productId, createdAt])
}

model Expense {
  id          String     @id @default(cuid())
  shopId      String
  title       String
  category    String
  amountCents Int
  dueDate     DateTime
  paidAt      DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  shop        BarberShop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, dueDate])
}

model Commission {
  id            String      @id @default(cuid())
  shopId        String
  barberId      String
  appointmentId String      @unique
  amountCents   Int
  rate          Decimal     @db.Decimal(5, 2)
  paidAt        DateTime?
  createdAt     DateTime    @default(now())
  shop          BarberShop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  barber        Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([shopId, paidAt])
  @@index([barberId, createdAt])
}

model Notification {
  id        String     @id @default(cuid())
  shopId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime   @default(now())
  shop      BarberShop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, readAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entity, entityId])
}
